# namespace.template
NAMESPACE=devops

# service.template, igress_route.template, deployment.web.template, pvc_host_path.template
NAME=vault

# igress_route.template (Traefik: suele ser web, websecure, etc.)
ENTRYPOINT=web

# igress_route.template
DOMAIN=vault.local

# deployment.web.template
IMAGE=vault:1.13.3
CPU=100m
MEMORY=250Mi
MOUNT_PATH=/vault/data

# pv_host_path.template, pvc_host_path.template
STORAGE=1Gi

# config_maps.template, secrets.template
CONFIG_PATH=/vault/config
CONFIG_FILE=vault.hcl
CONFIG="storage "file" {
  path = "/vault/data"
}

listener "tcp" {
  address     = "0.0.0.0:8200"
  tls_disable = 1
}

ui = true
disable_mlock = true
"