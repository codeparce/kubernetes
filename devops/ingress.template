apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: "${NAME}-ingress"
  namespace: ${NAMESPACE}
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: ${ENTRY}
spec:
  entryPoints:
    - ${ENTRY}
  routes:
    - match: Host(`${DOMAIN}`)
      kind: Rule
      services:
        - name: ${SERVICE}
          port: ${PORT}
  tls: {}